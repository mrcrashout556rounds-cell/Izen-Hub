local HipSlider = Main:CreateSlider({
    Name = "HipHeight",
    Range = {0, 10},
    Increment = 0.1,
    Suffix = "",
    CurrentValue = 2,
    Flag = "HipHeight",
    Callback = function(v)
        local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.HipHeight = v end
    end,
})

-- Jump Cooldown
local JumpCooldownSlider = Main:CreateSlider({
    Name = "Jump Cooldown",
    Range = {0, 2},
    Increment = 0.1,
    Suffix = "s",
    CurrentValue = 0,
    Flag = "JumpCooldown",
    Callback = function(v)
        _G.JumpCooldown = v
    end,
})

